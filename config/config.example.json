{
    "channels": {
        "slack": {
            "enabled": false,
            "token": "xoxb-YOUR-SLACK-BOT-TOKEN",
            "app_token": "xapp-YOUR-SLACK-APP-TOKEN",
            "signing_secret": "YOUR_SIGNING_SECRET"
        },
        "discord": {
            "enabled": false,
            "token": "YOUR_DISCORD_BOT_TOKEN"
        },
        "line": {
            "enabled": false,
            "channel_access_token": "YOUR_LINE_CHANNEL_ACCESS_TOKEN",
            "channel_secret": "YOUR_LINE_CHANNEL_SECRET",
            "webhook_path": "/webhook/line",
            "allow_from": []
        },
        "whatsapp": {
            "enabled": false,
            "token": "YOUR_WHATSAPP_TOKEN",
            "phone_number_id": "YOUR_PHONE_NUMBER_ID",
            "verify_token": "YOUR_VERIFY_TOKEN",
            "webhook_path": "/webhook/whatsapp",
            "allow_from": []
        },
        "telegram": {
            "enabled": false,
            "token": "YOUR_TELEGRAM_BOT_TOKEN",
            "allowFrom": [],
            "proxy": null
        },
        "feishu": {
            "enabled": false,
            "appId": "YOUR_FEISHU_APP_ID",
            "appSecret": "YOUR_FEISHU_APP_SECRET",
            "encryptKey": "YOUR_FEISHU_ENCRYPT_KEY",
            "verificationToken": "YOUR_FEISHU_VERIFICATION_TOKEN",
            "allowFrom": []
        }
    },
    "providers": {
        "fallback_order": [
            "vllm"
        ],
        "retry": {
            "max_attempts": 4,
            "backoff_seconds": 10
        },
        "anthropic": {
            "apiKey": "YOUR_ANTHROPIC_API_KEY",
            "apiBase": null,
            "extraHeaders": null
        },
        "openai": {
            "apiKey": "YOUR_OPENAI_API_KEY",
            "apiBase": null,
            "extraHeaders": null
        },
        "vllm": {
            "apiKey": "ollama",
            "apiBase": "http://127.0.0.1:11434/v1",
            "extraHeaders": null,
            "_note": "Ollama local LLM (configure your model name)"
        },
        "openrouter": {
            "apiKey": "YOUR_OPENROUTER_API_KEY",
            "apiBase": null,
            "extraHeaders": null
        },
        "deepseek": {
            "apiKey": "YOUR_DEEPSEEK_API_KEY",
            "apiBase": null,
            "extraHeaders": null
        },
        "groq": {
            "apiKey": "YOUR_GROQ_API_KEY",
            "apiBase": null,
            "extraHeaders": null
        },
        "gemini": {
            "apiKey": "YOUR_GEMINI_API_KEY",
            "apiBase": null,
            "extraHeaders": null
        }
    },
    "cron": {
        "heartbeat": {
            "enabled": false,
            "interval_minutes": 30,
            "prompt": "Send a heartbeat message.",
            "skip_if_busy": true
        }
    },
    "gateway": {
        "port": 8080,
        "host": "0.0.0.0"
    },
    "tools": {
        "web": {
            "search": {
                "apiKey": "YOUR_SEARCH_API_KEY",
                "maxResults": 5
            }
        },
        "exec": {
            "timeout": 120,
            "audit_log": true,
            "audit_log_path": "~/.nyancobot/logs/audit.jsonl"
        },
        "restrictToWorkspace": true,
        "allowed_dirs": [
            "~/.nyancobot/workspace",
            "/tmp"
        ],
        "policy": {
            "mode": "denylist",
            "denylist": [
                "spawn",
                "env",
                "printenv",
                "set",
                "export"
            ],
            "groups": {
                "fs": [
                    "read_file",
                    "write_file",
                    "edit_file",
                    "list_dir"
                ],
                "web": [
                    "web_search",
                    "web_fetch"
                ],
                "comm": [
                    "message",
                    "spawn"
                ]
            }
        }
    },
    "agents": {
        "defaults": {
            "workspace": "~/.nyancobot/workspace",
            "model": "YOUR_DEFAULT_MODEL",
            "maxTokens": 8192,
            "temperature": 0.7,
            "maxToolIterations": 20
        },
        "sanitize": {
            "enabled": true,
            "tag_external": true,
            "detect_injection": true,
            "url_denylist": [
                "localhost",
                "127.0.0.1",
                "192.168.",
                "10.",
                "169.254.",
                "0.0.0.0"
            ],
            "max_content_length": 10000
        },
        "link_understanding": {
            "enabled": true,
            "max_urls": 3,
            "max_length": 5000
        },
        "session": {
            "compaction": {
                "enabled": true,
                "threshold_tokens": 3000,
                "keep_recent": 3
            }
        },
        "task_board": {
            "enabled": true,
            "pin_board": true,
            "auto_update": true
        },
        "reflection": {
            "enabled": false,
            "max_reflections": 3,
            "threshold": 3.5,
            "auto_enable": false,
            "keywords": [
                "important",
                "report",
                "design",
                "plan",
                "proposal",
                "analysis"
            ]
        },
        "planner": {
            "enabled": false,
            "auto_detect": true,
            "max_steps": 10
        }
    },
    "mcpServers": {
        "denrei": {
            "command": "python3",
            "args": [
                "scripts/denrei-mcp-server.py"
            ]
        },
        "memory-search": {
            "command": "python3",
            "args": [
                "scripts/memory_search_server.py"
            ]
        },
        "web-tools": {
            "command": "python3",
            "args": [
                "scripts/web-tools-mcp-server.py"
            ]
        },
        "xai-search": {
            "command": "python3",
            "args": [
                "scripts/xai-search-mcp-server.py"
            ]
        },
        "browser-v2": {
            "command": "python3",
            "args": [
                "scripts/browser-mcp-server.py"
            ]
        }
    }
}
